# ============================================================
# PS13 — AIR-GAPPED PREDICTIVE COPILOT FOR SECURE MPLS OPS
# Environment Configuration (SANMIT - LOCAL)
# ============================================================

# --- Application ---
APP_ENV=development
APP_NAME="PS13 Predictive Copilot"
LOG_LEVEL=INFO

# --- Backend API ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
CORS_ORIGINS=http://localhost:3000

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ps13_db
POSTGRES_USER=ps13_user
POSTGRES_PASSWORD=sanmit_pg_pass_local
DATABASE_URL=postgresql+asyncpg://ps13_user:sanmit_pg_pass_local@postgres:5432/ps13_db

# --- InfluxDB ---
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=sanmit-influxdb-token-local-secure-key-2026
INFLUXDB_ORG=ps13
INFLUXDB_BUCKET=network_telemetry
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=sanmit_influx_admin_pass

# --- ChromaDB ---
CHROMA_HOST=chromadb
CHROMA_PORT=8100
CHROMA_COLLECTION=ps13_knowledge

# --- Ollama ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_FALLBACK_MODEL=phi3:mini
OLLAMA_TIMEOUT=120

# --- Prometheus ---
PROMETHEUS_URL=http://prometheus:9090

# --- Telemetry ---
SNMP_COMMUNITY=sanmit_snmp_community
SNMP_VERSION=2c
NETFLOW_PORT=9995
SYSLOG_PORT=514

# --- Network Digital Twin ---
TOPOLOGY_REFRESH_INTERVAL=30
RISK_CALC_INTERVAL=10
PREDICTION_INTERVAL=60

# --- ML Models ---
PROPHET_CHANGEPOINT_PRIOR=0.05
ISOLATION_FOREST_CONTAMINATION=0.1
XGBOOST_MAX_DEPTH=6
XGBOOST_LEARNING_RATE=0.1

# --- RAG ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7

# --- Security ---
SECRET_KEY=sanmit_secret_key_jwt_token_auth_local
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
AIR_GAPPED=true

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME="VIKRAM"
